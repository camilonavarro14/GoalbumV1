# ============================================
# Goalbum - Variables de Entorno
# Copia este archivo como .env y ajusta los valores
# ============================================

# URL del backend API (apunta al servicio NestJS)
VITE_API_URL=http://localhost:3000

# Nombre de la aplicación (se muestra en el login y otros lugares)
VITE_APP_NAME=Goalbum

# Versión de la aplicación (se muestra en el perfil y en el login)
VITE_APP_VERSION=1.0.0

# Dueño/copyright que aparece en el footer del login
VITE_APP_OWNER=camilonavarro14

# URL de la página de Términos y Condiciones (se enlaza en el registro)
# Si está vacío, el texto aparece sin enlace
VITE_TERMS_URL=https://tupagina.com/terminos

# Ambiente actual (TEST, DEV, STAGING, QA, PROD)
# Si es PROD o está vacío, no se muestra la barra de ambiente
VITE_APP_ENV=TEST
